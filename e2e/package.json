{
  "name": "e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:prod": "playwright test --config=playwright.prod.config.ts",
    "test:prod:headed": "playwright test --config=playwright.prod.config.ts --headed",
    "report": "playwright show-report",
    "report:prod": "playwright show-report playwright-report-prod"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "pg": "^8.13.0",
    "@types/pg": "^8.11.10",
    "@types/node": "^22.9.0"
  }
}
