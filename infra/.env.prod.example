# Copy to .env.prod on the VM and fill in real values.
# .env.prod itself MUST NOT be committed to git.

# The public hostname for HTTPS (no scheme, no path).
# Use nip.io for free: replace each "." in your VM's IPv4 with "-".
# Example: VM at 152.67.10.20 → taskflow-152-67-10-20.nip.io
DOMAIN=taskflow-X-X-X-X.nip.io

# Postgres credentials. Generate a strong password:
#   openssl rand -base64 32
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=taskflow

# JWT signing secret. Generate:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_chars_random

# Optional — defaults are reasonable. Short access + rotating refresh (PR 1).
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL_DAYS=30
